{
    "name": "ideal-10",
    "version": "1.0.0",
    "description": "Ideal 10 — Eleventy + Tailwind v4 static site",
    "private": true,
    "scripts": {
        "build": "npm-run-all --serial build:css build:html",
        "build:css": "tailwindcss -i assets/css/main.css -o _site/assets/css/main.css --minify",
        "build:html": "eleventy",
        "serve": "npm-run-all --serial dev:css:warmup dev:parallel",
        "dev:css:warmup": "tailwindcss -i assets/css/main.css -o _site/assets/css/main.css",
        "dev:parallel": "npm-run-all --parallel dev:css dev:html",
        "dev:css": "tailwindcss -i assets/css/main.css -o _site/assets/css/main.css --watch",
        "dev:html": "eleventy --serve",
        "clean": "rm -rf _site"
    },
    "devDependencies": {
        "@11ty/eleventy": "^3.0.0",
        "@tailwindcss/cli": "^4.0.0",
        "@tailwindcss/typography": "^0.5.15",
        "npm-run-all": "^4.1.5",
        "tailwindcss": "^4.0.0"
    },
    "dependencies": {
        "flowbite": "^2.5.2"
    }
}
