{
    "name": "ideal-10",
    "version": "1.0.0",
    "description": "Ideal 10 website",
    "scripts": {
        "build": "eleventy && tailwindcss -i assets/css/main.css -o _site/assets/css/main.css --minify",
        "serve": "npm-run-all --parallel serve:eleventy serve:css",
        "serve:eleventy": "eleventy --serve --watch",
        "serve:css": "tailwindcss -i assets/css/main.css -o _site/assets/css/main.css --watch"
    },
    "devDependencies": {
        "@11ty/eleventy": "^3.0.0",
        "@tailwindcss/cli": "^4.0.0",
        "@tailwindcss/typography": "^0.5.15",
        "npm-run-all": "^4.1.5",
        "tailwindcss": "^4.0.0"
    },
    "dependencies": {
        "flowbite": "^2.5.2"
    }
}
