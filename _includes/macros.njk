{#
  Site-wide Nunjucks macros — UI primitives and inline SVG icons.

  Usage
    {% from "macros.njk" import section_header, arrow_right, check_icon %}
    {{ section_header(kicker = "Servicios", heading = "...") }}
    <a class="btn-primary">Acción {{ arrow_right() }}</a>

  Conventions
    - Every macro that returns SVG accepts an optional `class` argument so the
      caller controls size and color.
    - `class` defaults to the most common size used on the site.
    - Strings rendered as HTML are emitted with `| safe` by the caller when
      needed (macros that return raw markup do not need `safe`).
#}

{#
  Standard section header: kicker label + heading + optional lead paragraph.

  @param kicker   short uppercase label rendered above the heading
  @param heading  main heading text
  @param lead     optional supporting paragraph
  @param tag      heading tag, defaults to "h2"
  @param size     "section" (default) or "page" — controls heading scale
#}
{% macro section_header(kicker, heading, lead = "", tag = "h2", size = "section") %}
    <div>
        <p class="kicker">{{ kicker }}</p>
        <{{ tag }} class="{% if size == 'page' %}heading-page{% else %}heading-section{% endif %}">{{ heading }}</{{ tag }}>
        {% if lead %}<p class="lead-lg">{{ lead }}</p>{% endif %}
    </div>
{% endmacro %}

{#
  Top-navigation link. Renders as active when `current` matches.

  @param href     destination URL
  @param label    link text
  @param current  current page URL (`page.url`)
  @param match    optional list of URL aliases that should also mark active
#}
{#
  Eleventy serves pretty URLs, so `page.url` is `/nosotros/` (trailing slash)
  while the nav data lists the canonical href without it. We strip a trailing
  slash on both sides before comparing so either spelling matches.

  Note: `replace` here is used as a portable "trim one trailing slash" — when
  the URL is just "/" the replacement no-ops because there's nothing to strip.
#}
{#
  We compare against `current` with both spellings (with and without trailing
  slash) so the macro works regardless of how Eleventy reports the URL.
#}
{% macro nav_link(href, label, current, match = []) %}
    {% set active = (current == href) or (current == href + "/") or (current + "/" == href) %}
    {% for alias in match %}
        {% if (current == alias) or (current == alias + "/") or (current + "/" == alias) %}
            {% set active = true %}
        {% endif %}
    {% endfor %}
    <li>
        <a href="{{ href }}" class="{% if active %}nav-link-active{% else %}nav-link{% endif %}"{% if active %} aria-current="page"{% endif %}>{{ label }}</a>
    </li>
{% endmacro %}

{# ----------------------------------------------------------------------- #}
{#  Icon library — keep stroke-based, currentColor SVGs.                    #}
{#  All icons accept a `class` for sizing and color.                        #}
{# ----------------------------------------------------------------------- #}

{# Right-pointing arrow used after CTA labels. #}
{% macro arrow_right(class = "h-4 w-4") %}
<svg class="{{ class }}" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
{% endmacro %}

{# Chevron used in "back" links. #}
{% macro chevron_left(class = "h-4 w-4") %}
<svg class="{{ class }}" aria-hidden="true" fill="none" viewBox="0 0 6 10" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 1 1 5l4 4"/></svg>
{% endmacro %}

{# Check mark used in feature lists. #}
{% macro check_icon(class = "h-4 w-4 text-emerald-500") %}
<svg class="{{ class }}" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
{% endmacro %}

