{# Standalone landing page rendered by `menu_entidades/*.html`. These pages
   are linked from third-party subdomains, so they intentionally do NOT
   inherit the main site layout (no navbar, no footer).

   Expected context: `name`, `links` (array of `{ href, name }`). #}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ name }} - Menú de Entidades</title>
    <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body class="flex min-h-screen flex-col items-center bg-slate-50 px-4 pt-10">
    <img src="/assets/img/big_logo_green.png" width="400" alt="IDEAL.10">

    <div class="mt-8 grid w-full max-w-5xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl md:grid-cols-2">
        <div class="flex items-center justify-center border-b border-slate-200 bg-emerald-50 p-8 md:border-b-0 md:border-r">
            <span class="rounded-xl bg-emerald-600 px-6 py-3 text-center text-lg font-bold text-white shadow-lg shadow-emerald-600/20">
                {{ name }}
            </span>
        </div>
        <ul class="space-y-3 p-8">
            {% for link in links %}
            <li>
                <a href="{{ link.href }}" class="block rounded-lg border border-emerald-100 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-600 hover:text-white">
                    {{ link.name }}
                </a>
            </li>
            {% endfor %}
        </ul>
    </div>
</body>
</html>
