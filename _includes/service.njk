{# Service card rendered from `_data/services.yml`.
   Expected context: `name`, `description`, `svg` (path under _includes). #}
<div class="card-interactive group">
    <div class="icon-tile icon-tile-hover mb-5 size-12 dark:group-hover:bg-emerald-600 dark:group-hover:text-white">
        {% include svg %}
    </div>
    <h3 class="text-base font-bold leading-7 text-slate-900 dark:text-white">{{ name }}</h3>
    <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">{{ description }}</p>
</div>
